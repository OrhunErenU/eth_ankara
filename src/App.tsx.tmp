// Speakers Section
function SpeakersSection() {
  const ref = useRef(null);
  const isInView = useInView(ref, { once: true, margin: "-100px" });
  const [dialogOpen, setDialogOpen] = useState(false);

  const speakers = [
    { name: 'Alex Chen', role: 'Protocol Engineer', image: '/speaker-1.jpg' },
    { name: 'Sarah Miller', role: 'DeFi Researcher', image: '/speaker-2.jpg' },
    { name: 'David Park', role: 'Security Auditor', image: '/speaker-3.jpg' },
    { name: 'Maya Johnson', role: 'Founder', image: '/speaker-4.jpg' },
    { name: 'James Wong', role: 'Core Dev', image: '/speaker-5.jpg' },
    { name: 'Emma Davis', role: 'Product Lead', image: '/speaker-6.jpg' },
  ];

  return (
    <section 
      id="speakers"
      ref={ref}
      className="relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden section-light  py-20"
    >
      {/* Headline */}
      <motion.h2
        initial={{ opacity: 0, x: -50 }}
        animate={isInView ? { opacity: 1, x: 0 } : {}}
        transition={{ duration: 0.8 }}
        className="section-title text-center text-dark-bg relative z-10 mb-4"
      >
        SPEAKERS
      </motion.h2>

      {/* Subheadline */}
      <motion.p
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.2 }}
        className="text-lg text-gray-600 text-center mb-12 relative z-10"
      >
        Builders, researchers, founders.
      </motion.p>

      {/* Speaker Grid */}
      <motion.div
        initial={{ opacity: 0, x: 60 }}
        animate={isInView ? { opacity: 1, x: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.3 }}
        className="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-4xl mx-auto px-6 relative z-10"
      >
        {speakers.map((speaker, index) => (
          <motion.div
            key={speaker.name}
            initial={{ opacity: 0, y: 20 }}
            animate={isInView ? { opacity: 1, y: 0 } : {}}
            transition={{ duration: 0.5, delay: 0.4 + index * 0.08 }}
            className="group text-center"
          >
            <div className="relative overflow-hidden rounded-xl mb-4 aspect-square">
              <img 
                src={speaker.image} 
                alt={speaker.name}
                className="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-300 group-hover:scale-105"
              />
              <div className="absolute inset-0 bg-cyan/10 opacity-0 group-hover:opacity-100 transition-opacity" />
            </div>
            <h3 className="font-display font-bold text-dark-bg">{speaker.name}</h3>
            <p className="text-sm text-gray-500">{speaker.role}</p>
          </motion.div>
        ))}
      </motion.div>

      {/* CTA */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.8 }}
        className="mt-12 relative z-10"
      >
        <Button 
          variant="outline"
          className="border-dark-bg/20 text-dark-bg hover:bg-dark-bg/10"
          onClick={() => setDialogOpen(true)}
        >
          Nominate a speaker
        </Button>
      </motion.div>

      {/* Nominate Dialog */}
      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
        <DialogContent className="bg-light-bg border border-gray-200">
          <DialogHeader>
            <DialogTitle className="font-display text-xl text-dark-bg">Nominate a Speaker</DialogTitle>
            <DialogDescription className="text-gray-600">
              Speaker nominations will open soon. Follow us on Twitter for updates!
            </DialogDescription>
          </DialogHeader>
        </DialogContent>
      </Dialog>

      {/* Footer bar */}
      <div className="absolute bottom-8 left-6 right-6 flex justify-between items-center text-sm text-gray-500">
        <span className="font-mono text-xs">LINEUP</span>
        <span className="font-mono text-xs">More announced soon</span>
      </div>
    </section>
  );
}

// Schedule Section
function ScheduleSection() {
  const ref = useRef(null);
  const isInView = useInView(ref, { once: true, margin: "-100px" });
  const [activeDay, setActiveDay] = useState(1);
  const [dialogOpen, setDialogOpen] = useState(false);

  return (
    <section 
      id="schedule"
      ref={ref}
      className="relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden section-dark  py-20"
    >
      {/* Wireframe Clock */}
      <motion.div
        initial={{ opacity: 0, scale: 0.65, rotate: -25 }}
        animate={isInView ? { opacity: 1, scale: 1, rotate: 0 } : {}}
        transition={{ duration: 1, ease: [0.22, 1, 0.36, 1] }}
        className="relative z-10 w-[50vw] max-w-[400px] mb-8"
      >
        <img 
          src="/clock-wireframe.png" 
          alt="Clock Wireframe" 
          className="w-full h-auto drop-shadow-[0_0_30px_rgba(24,191,255,0.3)]"
        />
      </motion.div>

      {/* Headline */}
      <motion.h2
        initial={{ opacity: 0, y: 40 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.2 }}
        className="section-title text-center text-white relative z-10"
      >
        SCHEDULE
      </motion.h2>

      {/* Day Tabs */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.4 }}
        className="flex gap-4 mt-10 relative z-10"
      >
        <button
          onClick={() => setActiveDay(1)}
          className={`px-6 py-3 rounded-full font-medium transition-all ${
            activeDay === 1 
              ? 'bg-cyan text-dark-bg' 
              : 'bg-dark-elevated text-text-secondary hover:text-white border border-white/10'
          }`}
        >
          Day 1
        </button>
        <button
          onClick={() => setActiveDay(2)}
          className={`px-6 py-3 rounded-full font-medium transition-all ${
            activeDay === 2 
              ? 'bg-cyan text-dark-bg' 
              : 'bg-dark-elevated text-text-secondary hover:text-white border border-white/10'
          }`}
        >
          Day 2
        </button>
      </motion.div>

      {/* Coming Soon Message */}
      <motion.div
        initial={{ opacity: 0 }}
        animate={isInView ? { opacity: 1 } : {}}
        transition={{ duration: 0.8, delay: 0.6 }}
        className="mt-10 text-center relative z-10"
      >
        <p className="text-text-secondary mb-4">Full schedule coming soon</p>
        <Button 
          variant="outline"
          className="border-white/20 text-white hover:bg-white/10"
          onClick={() => setDialogOpen(true)}
        >
          <Clock size={18} className="mr-2" />
          Get notified
        </Button>
      </motion.div>

      {/* Notification Dialog */}
      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
        <DialogContent className="bg-dark-bg border border-white/10">
          <DialogHeader>
            <DialogTitle className="font-display text-xl text-white">Schedule Updates</DialogTitle>
            <DialogDescription className="text-text-secondary">
              Subscribe to our newsletter to get the latest schedule updates!
            </DialogDescription>
          </DialogHeader>
        </DialogContent>
      </Dialog>

      {/* Footer bar */}
      <div className="absolute bottom-8 left-6 right-6 flex justify-between items-center text-sm text-text-secondary">
        <span className="font-mono text-xs">AGENDA</span>
        <span className="font-mono text-xs">Full program soon</span>
      </div>
    </section>
  );
}

