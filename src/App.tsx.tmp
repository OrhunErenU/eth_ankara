import { useEffect, useRef, useState } from 'react';
import { motion, useInView } from 'framer-motion';
import { 
  MapPin, 
  Calendar, 
  Mic, 
  Wrench, 
  Users, 
  Clock, 
  Ticket, 
  Mail, 
  Twitter, 
  Send,
  Github,
  ArrowRight,
  Menu,
  X
} from 'lucide-react';
import { Button } from '@/components/ui/button';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogDescription } from '@/components/ui/dialog';
import './App.css';

// Navigation Component
function Navigation() {
  const [isScrolled, setIsScrolled] = useState(false);
  const [mobileMenuOpen, setMobileMenuOpen] = useState(false);

  useEffect(() => {
    const handleScroll = () => {
      setIsScrolled(window.scrollY > 100);
    };
    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  const navLinks = [
    { label: 'Expect', href: '#expect' },
    { label: 'Speakers', href: '#speakers' },
    { label: 'Schedule', href: '#schedule' },
    { label: 'Sponsors', href: '#sponsors' },
    { label: 'Tickets', href: '#tickets' },
    { label: 'Team', href: '/team', external: true },
  ];

  const scrollToSection = (href: string) => {
    const element = document.querySelector(href);
    if (element) {
      element.scrollIntoView({ behavior: 'smooth' });
    }
    setMobileMenuOpen(false);
  };

  return (
    <>
      <motion.nav
        initial={{ y: -100 }}
        animate={{ y: 0 }}
        className={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${
          isScrolled ? 'bg-dark-bg/90 backdrop-blur-md border-b border-white/5' : ''
        }`}
      >
        <div className="w-full px-6 lg:px-12 py-4 flex items-center justify-between">
          <a href="#" className="font-display font-bold text-xl tracking-tight text-white">
            ETH<span className="text-cyan">ANKARA</span>
          </a>
          
          {/* Desktop Nav */}
          <div className="hidden md:flex items-center gap-8">
            {navLinks.map((link) => (
              link.external ? (
                <a
                  key={link.label}
                  href={link.href}
                  className="text-sm text-text-secondary hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              ) : (
                <button
                  key={link.label}
                  onClick={() => scrollToSection(link.href)}
                  className="text-sm text-text-secondary hover:text-white transition-colors"
                >
                  {link.label}
                </button>
              )
            ))}
            <Button 
              onClick={() => scrollToSection('#tickets')}
              className="bg-cyan text-dark-bg hover:bg-cyan/90 font-medium"
            >
              Get Tickets
            </Button>
          </div>

          {/* Mobile Menu Button */}
          <button 
            className="md:hidden text-white"
            onClick={() => setMobileMenuOpen(!mobileMenuOpen)}
          >
            {mobileMenuOpen ? <X size={24} /> : <Menu size={24} />}
          </button>
        </div>
      </motion.nav>

      {/* Mobile Menu */}
      <Dialog open={mobileMenuOpen} onOpenChange={setMobileMenuOpen}>
        <DialogContent className="bg-dark-bg border border-white/10 w-[90vw] max-w-sm">
          <DialogHeader>
            <DialogTitle className="font-display text-xl text-white">Menu</DialogTitle>
          </DialogHeader>
          <div className="flex flex-col gap-4 py-4">
            {navLinks.map((link) => (
              link.external ? (
                <a
                  key={link.label}
                  href={link.href}
                  className="text-left text-lg text-text-secondary hover:text-white transition-colors py-2"
                  onClick={() => setMobileMenuOpen(false)}
                >
                  {link.label}
                </a>
              ) : (
                <button
                  key={link.label}
                  onClick={() => scrollToSection(link.href)}
                  className="text-left text-lg text-text-secondary hover:text-white transition-colors py-2"
                >
                  {link.label}
                </button>
              )
            ))}
            <Button 
              onClick={() => scrollToSection('#tickets')}
              className="bg-cyan text-dark-bg hover:bg-cyan/90 font-medium mt-4"
            >
              Get Tickets
            </Button>
          </div>
        </DialogContent>
      </Dialog>
    </>
  );
}

// Hero Section
function HeroSection() {
  const ref = useRef(null);
  const isInView = useInView(ref, { once: true });

  return (
    <section 
      ref={ref}
      className="relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden section-dark "
    >
      {/* Background gradient */}
      <div className="absolute inset-0 " />
      
      {/* Wireframe ETH Logo */}
      <motion.div
        initial={{ opacity: 0, scale: 0.8, rotateX: 25 }}
        animate={isInView ? { opacity: 1, scale: 1, rotateX: 0 } : {}}
        transition={{ duration: 1.2, ease: [0.22, 1, 0.36, 1] }}
        className="relative z-10 w-[60vw] max-w-[500px] mb-8"
      >
        <img 
          src="/eth-wireframe.png" 
          alt="ETH Wireframe" 
          className="w-full h-auto animate-float drop-shadow-[0_0_30px_rgba(24,191,255,0.3)]"
        />
      </motion.div>

      {/* Headline */}
      <motion.h1
        initial={{ opacity: 0, y: 30 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.3, ease: [0.22, 1, 0.36, 1] }}
        className="hero-title text-center text-white relative z-10"
      >
        ETH ANKARA
      </motion.h1>

      {/* Subheadline */}
      <motion.p
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.5 }}
        className="mt-6 text-lg md:text-xl text-text-secondary text-center relative z-10"
      >
        May 23–24, 2026 · Ankara, Turkey
      </motion.p>

      {/* CTAs */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.7 }}
        className="flex flex-col sm:flex-row gap-4 mt-10 relative z-10"
      >
        <Button 
          size="lg"
          className="bg-cyan text-dark-bg hover:bg-cyan/90 font-semibold px-8"
          onClick={() => document.querySelector('#tickets')?.scrollIntoView({ behavior: 'smooth' })}
        >
          Get Tickets
        </Button>
        <Button 
          size="lg"
          variant="outline"
          className="border-white/20 text-white hover:bg-white/10"
          onClick={() => document.querySelector('#schedule')?.scrollIntoView({ behavior: 'smooth' })}
        >
          View Schedule
        </Button>
      </motion.div>

      {/* Footer bar */}
      <motion.div
        initial={{ opacity: 0 }}
        animate={isInView ? { opacity: 1 } : {}}
        transition={{ duration: 0.8, delay: 0.9 }}
        className="absolute bottom-8 left-6 right-6 flex justify-between items-center text-sm text-text-secondary"
      >
        <span className="font-mono text-xs">#ETHANKARA</span>
        <span className="font-mono text-xs hidden sm:inline">Scroll to explore</span>
      </motion.div>
    </section>
  );
}

