        initial={{ opacity: 0, y: 30 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.6 }}
        className="flex flex-wrap justify-center gap-6 mt-10 relative z-10"
      >
        {sponsorTiers.map((tier) => (
          <div 
            key={tier.name}
            className="px-6 py-4 bg-dark-elevated border border-white/10 rounded-xl text-center min-w-[140px]"
          >
            <p className="font-mono text-xs text-text-secondary mb-1">{tier.name}</p>
            <p className="font-display text-2xl font-bold text-cyan">{tier.count}</p>
            <p className="text-xs text-text-secondary">spots</p>
          </div>
        ))}
      </motion.div>

      {/* CTA */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.8 }}
        className="mt-10 relative z-10"
      >
        <Button 
          variant="outline"
          className="border-white/20 text-white hover:bg-white/10"
          onClick={() => setDialogOpen(true)}
        >
          Become a sponsor
        </Button>
      </motion.div>

      {/* Sponsor Dialog */}
      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
        <DialogContent className="bg-dark-bg border border-white/10">
          <DialogHeader>
            <DialogTitle className="font-display text-xl text-white">Become a Sponsor</DialogTitle>
            <DialogDescription className="text-text-secondary">
              Sponsor packages will be announced soon. Contact us at hello@ethankara.xyz for early inquiries.
            </DialogDescription>
          </DialogHeader>
        </DialogContent>
      </Dialog>

      {/* Footer bar */}
      <div className="absolute bottom-8 left-6 right-6 flex justify-between items-center text-sm text-text-secondary">
        <span className="font-mono text-xs">PARTNERS</span>
        <span className="font-mono text-xs">Packages & contact</span>
      </div>
    </section>
  );
}

// Tickets Section
function TicketsSection() {
  const ref = useRef(null);
  const isInView = useInView(ref, { once: true, margin: "-100px" });
  const [dialogOpen, setDialogOpen] = useState(false);

  return (
    <section 
      id="tickets"
      ref={ref}
      className="relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden section-light  py-20"
    >
      {/* Wireframe Ticket */}
      <motion.div
        initial={{ opacity: 0, x: 60, rotate: -12 }}
        animate={isInView ? { opacity: 1, x: 0, rotate: 0 } : {}}
        transition={{ duration: 1, ease: [0.22, 1, 0.36, 1] }}
        className="relative z-10 w-[60vw] max-w-[500px] mb-8"
      >
        <img 
          src="/ticket-wireframe.png" 
          alt="Ticket Wireframe" 
          className="w-full h-auto"
          style={{ filter: 'drop-shadow(0 0 20px rgba(24,191,255,0.2))' }}
        />
      </motion.div>

      {/* Headline */}
      <motion.h2
        initial={{ opacity: 0, y: 40 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.2 }}
        className="section-title text-center text-dark-bg relative z-10"
      >
        TICKETS
      </motion.h2>

      {/* Subheadline */}
      <motion.p
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.4 }}
        className="mt-6 text-lg text-gray-600 text-center relative z-10"
      >
        Early bird ends soon.
      </motion.p>

      {/* CTA */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8, delay: 0.6 }}
        className="mt-10 relative z-10"
      >
        <Button 
          size="lg"
          className="bg-green text-dark-bg hover:bg-green/90 font-semibold px-8"
          onClick={() => setDialogOpen(true)}
        >
          <Ticket size={18} className="mr-2" />
          Get Early Bird
        </Button>
      </motion.div>

      {/* Info */}
      <motion.p
        initial={{ opacity: 0 }}
        animate={isInView ? { opacity: 1 } : {}}
        transition={{ duration: 0.8, delay: 0.8 }}
        className="mt-6 text-sm text-gray-500 relative z-10"
      >
        Student discounts available
      </motion.p>

      {/* Ticket Dialog */}
      <Dialog open={dialogOpen} onOpenChange={setDialogOpen}>
        <DialogContent className="bg-light-bg border border-gray-200">
          <DialogHeader>
            <DialogTitle className="font-display text-xl text-dark-bg">Tickets Coming Soon</DialogTitle>
            <DialogDescription className="text-gray-600">
              Ticket sales will open soon. Follow us on Twitter and Telegram to be the first to know!
            </DialogDescription>
          </DialogHeader>
        </DialogContent>
      </Dialog>

      {/* Footer bar */}
      <div className="absolute bottom-8 left-6 right-6 flex justify-between items-center text-sm text-gray-500">
        <span className="font-mono text-xs">ACCESS</span>
        <span className="font-mono text-xs">Student discounts available</span>
      </div>
    </section>
  );
}

// Contact/Footer Section
function ContactSection() {
  const ref = useRef(null);
  const isInView = useInView(ref, { once: true, margin: "-100px" });
  const [email, setEmail] = useState('');
  const [subscribed, setSubscribed] = useState(false);

  const handleSubscribe = (e: React.FormEvent) => {
    e.preventDefault();
    if (email) {
      setSubscribed(true);
      setEmail('');
    }
  };

  return (
    <section 
      ref={ref}
      className="relative w-full overflow-hidden section-dark  py-20 lg:py-32"
    >
      <div className="max-w-6xl mx-auto px-6">
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-16">
          {/* Newsletter */}
          <motion.div
            initial={{ opacity: 0, x: -50 }}
            animate={isInView ? { opacity: 1, x: 0 } : {}}
            transition={{ duration: 0.8 }}
          >
            <h3 className="font-display text-3xl font-bold text-white mb-4">
              Stay in the loop
            </h3>
            <p className="text-text-secondary mb-8">
              Get the latest updates on speakers, schedule, and ticket releases.
            </p>
            
            {subscribed ? (
              <div className="p-4 bg-green/10 border border-green/30 rounded-lg">
                <p className="text-green font-medium">Thanks for subscribing!</p>
              </div>
            ) : (
              <form onSubmit={handleSubscribe} className="flex gap-3">
                <input
                  type="email"
                  value={email}
                  onChange={(e) => setEmail(e.target.value)}
                  placeholder="Email address"
                  className="flex-1 px-4 py-3 bg-dark-elevated border border-white/10 rounded-lg text-white placeholder:text-text-secondary focus:outline-none focus:border-cyan/50"
                  required
                />
                <Button type="submit" className="bg-cyan text-dark-bg hover:bg-cyan/90">
                  Subscribe
                </Button>
              </form>
            )}
          </motion.div>

          {/* Contact Links */}
          <motion.div
            initial={{ opacity: 0, x: 50 }}
            animate={isInView ? { opacity: 1, x: 0 } : {}}
            transition={{ duration: 0.8, delay: 0.2 }}
            className="space-y-6"
          >
            <h3 className="font-display text-3xl font-bold text-white mb-4">
              Connect with us
            </h3>
            
            <div className="space-y-4">
              <a 
                href="mailto:hello@ethankara.xyz" 
                className="flex items-center gap-3 text-text-secondary hover:text-cyan transition-colors"
              >
                <Mail size={20} />
                <span>hello@ethankara.xyz</span>
              </a>
              <a 
                href="https://twitter.com/ethankara" 
                target="_blank" 
                rel="noopener noreferrer"
                className="flex items-center gap-3 text-text-secondary hover:text-cyan transition-colors"
              >
                <Twitter size={20} />
                <span>Twitter / X</span>
              </a>
              <a 
                href="https://t.me/ethankara" 
                target="_blank" 
                rel="noopener noreferrer"
                className="flex items-center gap-3 text-text-secondary hover:text-cyan transition-colors"
              >
                <Send size={20} />
                <span>Telegram</span>
              </a>
              <a 
                href="https://github.com/ethankara" 
                target="_blank" 
                rel="noopener noreferrer"
                className="flex items-center gap-3 text-text-secondary hover:text-cyan transition-colors"
              >
                <Github size={20} />
                <span>GitHub</span>
              </a>
            </div>
          </motion.div>
        </div>

        {/* Bottom bar */}
        <motion.div
          initial={{ opacity: 0 }}
          animate={isInView ? { opacity: 1 } : {}}
          transition={{ duration: 0.8, delay: 0.4 }}
          className="mt-20 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4"
        >
          <p className="text-sm text-text-secondary">
            © 2026 ETH Ankara. All rights reserved.
          </p>
          <a href="#" className="text-sm text-text-secondary hover:text-white transition-colors">
            Code of Conduct
          </a>
        </motion.div>
      </div>
    </section>
  );
}

// Main App
function App() {
  return (
    <div className="relative">
      <Navigation />
      <main>
        <HeroSection />
        <LocationSection />
        <ExpectSection />
        <HackathonSection />
        <SpeakersSection />
        <ScheduleSection />
        <SponsorsSection />
        <TicketsSection />
        <ContactSection />
      </main>
    </div>
  );
}

export default App;
