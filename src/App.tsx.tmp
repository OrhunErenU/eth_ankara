// What to Expect Section
function ExpectSection() {
  const ref = useRef(null);
  const isInView = useInView(ref, { once: true, margin: "-100px" });

  const cards = [
    {
      icon: Mic,
      title: 'Talks',
      description: 'Keynotes and panels on Ethereum, security, and DeFi.',
    },
    {
      icon: Wrench,
      title: 'Workshops',
      description: 'Hands-on sessions for builders of all levels.',
    },
    {
      icon: Users,
      title: 'Networking',
      description: 'Meet teams, mentors, and future collaborators.',
    },
  ];

  return (
    <section 
      id="expect"
      ref={ref}
      className="relative min-h-screen w-full flex flex-col items-center justify-center overflow-hidden section-dark  py-20"
    >
      {/* Section Title */}
      <motion.h2
        initial={{ opacity: 0, y: -30 }}
        animate={isInView ? { opacity: 1, y: 0 } : {}}
        transition={{ duration: 0.8 }}
        className="section-title text-center text-white relative z-10 mb-16"
      >
        WHAT TO EXPECT
      </motion.h2>

      {/* Cards */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto px-6 relative z-10">
        {cards.map((card, index) => (
          <motion.div
            key={card.title}
            initial={{ opacity: 0, x: index === 0 ? -60 : index === 2 ? 60 : 0, y: index === 1 ? 60 : 0 }}
            animate={isInView ? { opacity: 1, x: 0, y: 0 } : {}}
            transition={{ duration: 0.8, delay: 0.2 + index * 0.1 }}
            className="group p-8 bg-dark-elevated border border-white/10 rounded-xl hover:border-cyan/30 transition-all duration-300 hover:-translate-y-2"
          >
            <div className="w-12 h-12 flex items-center justify-center bg-cyan/10 rounded-lg mb-6">
              <card.icon size={24} className="text-cyan" />
            </div>
            <h3 className="font-display text-2xl font-bold text-white mb-4">{card.title}</h3>
            <p className="text-text-secondary leading-relaxed">{card.description}</p>
          </motion.div>
        ))}
      </div>

      {/* Footer bar */}
      <div className="absolute bottom-8 left-6 right-6 flex justify-between items-center text-sm text-text-secondary">
        <span className="font-mono text-xs">OVERVIEW</span>
        <span className="font-mono text-xs">Why attend</span>
      </div>
    </section>
  );
}

